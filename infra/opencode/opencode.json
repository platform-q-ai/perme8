{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "write": "allow"
  },
  "mcp": {
    "perme8-mcp": {
      "type": "remote",
      "url": "__PERME8_MCP_URL__",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer __PERME8_MCP_API_KEY__"
      }
    }
  }
}
