# Test environment overrides
# Loaded by config/test.exs before database configuration.
# In docker-compose: this file is used as-is (port 5433 = postgres_test service).
# In session containers: the entrypoint overwrites this file to use port 5432.

# Database URL for local docker-compose (postgres_test maps host 5433 → container 5432)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/jarga_test

# Fast debounce time for tests (1ms instead of 2000ms)
PAGE_SAVE_DEBOUNCE_MS=1
