# Test environment overrides
# Loaded by config/test.exs before database configuration.
# Pre-existing env vars (e.g. CI) take precedence.

# Database URL — same PostgreSQL instance as dev, different database
DATABASE_URL=postgres://postgres:postgres@localhost/jarga_test

# Fast debounce time for tests (1ms instead of 2000ms)
PAGE_SAVE_DEBOUNCE_MS=1
