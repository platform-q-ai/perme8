<Layouts.admin flash={@flash} current_scope={@current_scope} full_width={true}>
  <div id="browser-notifications-hook" phx-hook="BrowserNotifications"></div>
  <div class="flex flex-col lg:flex-row flex-1 min-h-0">
    <%!-- Left Panel: Session List --%>
    <div class={[
      "lg:w-1/2 lg:shrink-0 border-r border-base-300 flex flex-col bg-base-100",
      if(@mobile_panel == :detail, do: "hidden lg:flex", else: "flex-1 lg:flex-initial")
    ]}>
      <.sidebar_header
        syncing_tickets={@syncing_tickets}
        auth_refreshing={@auth_refreshing}
        sessions={@sessions}
        tickets={@tickets}
      />

      <div class="flex-1 overflow-hidden flex flex-col">
        <%= if @sessions == [] and @tickets == [] do %>
          <div class="p-6 text-center text-base-content/50 text-sm">
            <.icon name="hero-chat-bubble-left-right" class="size-8 mx-auto mb-2 opacity-40" />
            <p>No sessions yet</p>
          </div>
        <% else %>
          <%!-- Apply unified search and status filter across both columns --%>
          <% filtered_sessions =
            @sessions
            |> filter_sessions_by_search(@session_search)
            |> filter_sessions_by_status(@status_filter) %>
          <% filtered_tickets =
            @tickets
            |> filter_tickets_by_search(@session_search)
            |> filter_tickets_by_status(@status_filter) %>
          <%!-- Flattened ticket list (includes sub-tickets) for association lookups --%>
          <% all_tickets_flat =
            Enum.flat_map(@tickets, fn t -> [t | t.sub_tickets || []] end) %>

          <.search_and_filter session_search={@session_search} status_filter={@status_filter} />

          <%!-- Partition tickets into idle (triage) vs active pipeline work --%>
          <%!-- Sub-tickets participate identically to root tickets in lane partitioning --%>
          <% build_statuses = ["pending", "starting", "running", "queued"] %>
          <% filtered_tickets_flat =
            Enum.flat_map(filtered_tickets, fn t -> [t | t.sub_tickets || []] end) %>
          <% active_tickets =
            Enum.filter(filtered_tickets_flat, fn t -> t.task_status in build_statuses end) %>
          <% active_ticket_numbers = MapSet.new(active_tickets, & &1.number) %>
          <% warming_task_ids =
            if @queue_state,
              do: MapSet.new(Map.get(@queue_state, :warming_task_ids, [])),
              else: MapSet.new() %>
          <% warm_candidate_ids = @sticky_warm_task_ids || MapSet.new() %>
          <% has_real_container? = fn session ->
            is_binary(session.container_id) and
              not String.starts_with?(session.container_id, "task:")
          end %>
          <% session_variant = fn session ->
            cond do
              session.latest_status in ["running", "starting", "pending"] ->
                :in_progress

              session.latest_status == "failed" ->
                :failed

              session.latest_status == "queued" and is_binary(session.latest_task_id) and
                  MapSet.member?(warm_candidate_ids, session.latest_task_id) ->
                :warm

              session.latest_status == "queued" ->
                :queued

              true ->
                :triage_session
            end
          end %>
          <% session_warming? = fn session ->
            is_binary(session.latest_task_id) and
              MapSet.member?(warming_task_ids, session.latest_task_id) and
              not has_real_container?.(session)
          end %>
          <%!-- idle_tickets: root tickets not in build. Sub-tickets render in the parent accordion --%>
          <% idle_tickets =
            filtered_tickets
            |> Enum.filter(fn t -> t.task_status not in build_statuses end)
            |> Enum.sort_by(fn t ->
              case t.task_status do
                "awaiting_feedback" -> 0
                "failed" -> 1
                "completed" -> 2
                "cancelled" -> 3
                _ -> 4
              end
            end) %>
          <%!-- Association lookups use unfiltered @tickets/@sessions intentionally:
             when a search/status filter hides one side of a session<->ticket pair,
             the visible side must still resolve its association for correct rendering
             (e.g. showing the ticket badge on a visible session whose ticket is filtered out). --%>
          <% ticket_for_session = fn session ->
            direct =
              Enum.find(all_tickets_flat, &(&1.associated_container_id == session.container_id))

            task_id_match =
              if session.latest_task_id,
                do:
                  Enum.find(all_tickets_flat, &(&1.associated_task_id == session.latest_task_id)),
                else: nil

            task_instruction =
              (@tasks_snapshot || [])
              |> Enum.find(&(&1.id == session.latest_task_id))
              |> case do
                %{instruction: instruction} when is_binary(instruction) -> instruction
                _ -> nil
              end

            inferred_number =
              [session.title, task_instruction]
              |> Enum.find_value(fn text ->
                case Agents.Tickets.extract_ticket_number(text) do
                  number when is_integer(number) and number > 0 -> number
                  _ -> nil
                end
              end)

            direct || task_id_match ||
              case inferred_number do
                number when is_integer(number) ->
                  Enum.find(all_tickets_flat, &(&1.number == number))

                _ ->
                  nil
              end
          end %>

          <%!-- Helper: find the session for a ticket --%>
          <% session_for_ticket = fn ticket ->
            Enum.find(@sessions, fn s ->
              s.container_id == ticket.associated_container_id ||
                s.latest_task_id == ticket.associated_task_id
            end)
          end %>

          <%!-- Non-ticket sessions: triage (completed/cancelled/awaiting_feedback) and build --%>
          <% non_ticket_triage_sessions =
            filtered_sessions
            |> Enum.filter(fn s ->
              is_nil(ticket_for_session.(s))
            end)
            |> Enum.sort_by(fn s ->
              priority =
                case s.latest_status do
                  "awaiting_feedback" -> 0
                  status when status in ["completed", "cancelled"] -> 1
                  "failed" -> 2
                  "queued" -> 3
                  status when status in ["running", "starting", "pending"] -> 4
                  _ -> 5
                end

              {priority, -latest_at_unix(s)}
            end) %>
          <% optimistic_queued_sessions =
            @optimistic_new_sessions
            |> Enum.sort_by(fn entry ->
              case entry[:queued_at] do
                %DateTime{} = dt -> -DateTime.to_unix(dt, :microsecond)
                _ -> 0
              end
            end) %>

          <div class="flex-1 min-h-0 p-2 w-full h-full items-stretch">
            <.triage_column
              non_ticket_triage_sessions={non_ticket_triage_sessions}
              optimistic_queued_sessions={optimistic_queued_sessions}
              idle_tickets={idle_tickets}
              active_ticket_numbers={active_ticket_numbers}
              active_container_id={@active_container_id}
              active_ticket_number={@active_ticket_number}
              collapsed_parents={@collapsed_parents}
              syncing_tickets={@syncing_tickets}
              container_stats={@container_stats}
              session_for_ticket={session_for_ticket}
              session_variant={session_variant}
              session_warming?={session_warming?}
              ticket_data_id={&ticket_data_id/1}
            />
          </div>
        <% end %>
      </div>

      <.pipeline_kanban
        :if={@sessions != [] or @tickets != []}
        kanban={@pipeline_kanban}
        collapsed={@pipeline_kanban_collapsed}
        collapsed_columns={@collapsed_kanban_columns}
        active_ticket_number={@active_ticket_number}
      />

      <.pipeline_editor
        :if={@pipeline_editor_authorized?}
        draft={@pipeline_editor_draft}
        errors={@pipeline_editor_errors}
        load_failed={@pipeline_editor_load_failed?}
        saved_at={@pipeline_editor_saved_at}
        saving={@pipeline_editor_saving}
      />
    </div>

    <% selected_ticket =
      @selected_ticket || find_ticket_by_number(@tickets, @active_ticket_number) %>
    <% detail_tabs = @detail_tabs || [%{id: "chat", label: "Chat"}] %>

    <%!-- Right Panel: Active Session Detail --%>
    <div class={[
      "flex-1 flex flex-col min-w-0 overflow-hidden",
      if(@mobile_panel == :list, do: "hidden lg:flex", else: "flex")
    ]}>
      <%!-- Mobile back button (visible only on small screens) --%>
      <button
        type="button"
        phx-click="show_mobile_panel"
        phx-value-panel="list"
        class="lg:hidden flex items-center gap-1 px-3 py-2 text-sm text-base-content/70 hover:text-base-content border-b border-base-300 bg-base-100"
      >
        <.icon name="hero-chevron-left" class="size-4" />
        <span>Sessions</span>
      </button>

      <%= if @active_container_id || @current_task || @composing_new do %>
        <.session_detail_header
          current_task={@current_task}
          session_title={@session_title}
          session_model={@session_model}
          selected_ticket={selected_ticket}
          active_container_id={@active_container_id}
          sessions={@sessions}
          current_scope={@current_scope}
        />

        <%!-- Tab bar --%>
        <.tab_bar
          active_tab={@active_session_tab}
          tabs={detail_tabs}
        />

        <%!-- Chat tab panel --%>
        <.chat_tab_panel
          :if={@active_session_tab == "chat"}
          current_task={@current_task}
          session_tokens={@session_tokens}
          session_summary={@session_summary}
          output_parts={@output_parts}
          queued_messages={@queued_messages}
          pending_question={@pending_question}
          auth_refreshing={@auth_refreshing}
        />

        <%!-- Ticket tab panel --%>
        <% parent_ticket =
          if selected_ticket, do: find_parent_ticket(@tickets, selected_ticket), else: nil %>
        <.ticket_tab_panel
          :if={@active_session_tab == "ticket"}
          selected_ticket={selected_ticket}
          parent_ticket={parent_ticket}
          dependency_search_mode={@dependency_search_mode}
          dependency_search_query={@dependency_search_query}
          dependency_search_results={@dependency_search_results}
          selected_dependency_target={@selected_dependency_target}
          dependency_direction={@dependency_direction}
          fixture={@fixture}
        />

        <.pr_tab_panel
          :if={@active_session_tab == "pr"}
          selected_pull_request={@selected_pull_request}
          pr_diff_payload={@pr_diff_payload}
          pr_review_threads={@pr_review_threads}
          pr_loading={@pr_loading}
          pr_error={@pr_error}
          show_inline_comment_form={@show_inline_comment_form}
          pr_review_decision={@pr_review_decision}
        />

        <%!-- Input form stays visible across tabs --%>
        <.session_input_form
          current_task={@current_task}
          composing_new={@composing_new}
          available_images={@available_images}
          selected_image={@selected_image}
          active_container_id={@active_container_id}
          active_session_tab={@active_session_tab}
          active_ticket_number={@active_ticket_number}
          todo_items={@todo_items}
          form={@form}
        />
      <% else %>
        <%!-- Empty state — no session selected --%>
        <div class="flex-1 flex flex-col items-center justify-center text-base-content/40 p-8">
          <.icon name="hero-command-line" class="size-16 mb-4" />
          <h3 class="text-lg font-semibold mb-2">No sessions yet</h3>
          <p class="text-sm text-center max-w-sm mb-4">
            Start a new coding session to run tasks in containers with opencode.
          </p>
          <button type="button" phx-click="new_session" class="btn btn-primary btn-sm">
            <.icon name="hero-plus" class="size-4" /> New Session
          </button>
        </div>
      <% end %>
    </div>
  </div>
</Layouts.admin>
